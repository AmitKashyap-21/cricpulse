# CricAPI key — get free key at https://www.cricapi.com/
CRICAPI_API_KEY=your_cricapi_key_here

# Redis connection
REDIS_HOST=localhost
REDIS_PORT=6379

# TTLs (seconds)
MATCH_SNAPSHOT_TTL=30
MATCHES_LIST_TTL=60
RATE_LIMIT_WINDOW=60

# Rate limit (requests per window)
RATE_LIMIT_MAX=30

# Scheduler (milliseconds between polls; default: 8000)
POLL_INTERVAL_MS=8000
# Max live matches to poll per cycle (default: 20)
MAX_POLL_MATCHES=20

# App
PORT=3000
FRONTEND_ORIGIN=http://localhost:3001
