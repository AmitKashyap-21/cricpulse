# RapidAPI Cricbuzz — get key at https://rapidapi.com/cricketapilive/api/cricbuzz-cricket
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=cricbuzz-cricket.p.rapidapi.com
RAPIDAPI_BASE_URL=https://cricbuzz-cricket.p.rapidapi.com

# Matches list endpoint path (default: /matches/v1/live)
RAPIDAPI_MATCHES_PATH=/matches/v1/live

# Redis connection
REDIS_HOST=localhost
REDIS_PORT=6379

# TTLs (seconds)
MATCH_SNAPSHOT_TTL=30
MATCHES_LIST_TTL=60
RATE_LIMIT_WINDOW=60

# Rate limit (requests per window)
RATE_LIMIT_MAX=30

# Scheduler (milliseconds between polls; default: 8000)
POLL_INTERVAL_MS=8000
# Max live matches to poll per cycle (default: 20)
MAX_POLL_MATCHES=20

# App
PORT=3000
FRONTEND_ORIGIN=http://localhost:3001
