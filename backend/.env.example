# RapidAPI Cricbuzz — get key at https://rapidapi.com/cricketapilive/api/cricbuzz-cricket
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=cricbuzz-cricket.p.rapidapi.com
RAPIDAPI_BASE_URL=https://cricbuzz-cricket.p.rapidapi.com

# Redis connection
REDIS_HOST=localhost
REDIS_PORT=6379

# Cache TTLs (seconds)
# Match details cache (scorecard + commentary + overs) — default 10s
MATCH_DETAILS_TTL=10
# Match list cache (live + recent + upcoming) — default 30s
MATCHES_LIST_TTL=30
# Rate-limit sliding window in seconds
RATE_LIMIT_WINDOW=60

# Max requests per RATE_LIMIT_WINDOW
RATE_LIMIT_MAX=30

# Scheduler (milliseconds between live polls; default: 8000)
POLL_INTERVAL_MS=8000
# Max live matches to deep-poll per cycle (default: 20)
MAX_POLL_MATCHES=20

# App
PORT=3000
FRONTEND_ORIGIN=http://localhost:3001
